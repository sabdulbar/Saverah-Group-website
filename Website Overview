<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Saverah Group — Bringing People and Businesses Together</title>
<meta name="description" content="Saverah is the ultimate benchmark in lifestyle events, products and services, empowering the ethnic community in the UK. Discover Saverah Events, Saverah Village and SELF.">
<meta property="og:title" content="Saverah Group">
<meta property="og:description" content="Bringing people and businesses together. Together, We Grow.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#FBFAF7;
  --bg-alt:#F4F1E9;
  --card:#FFFFFF;
  --ink:#0B1226;
  --ink-2:#525B70;
  --dark:#0A0F22;
  --dark-2:#111A38;
  --gold:#B8924A;
  --gold-soft:#E9DDBD;
  --champagne:#EAD7A4;
  --rose:#B96A7E;
  --rose-soft:#E9CBD3;
  --border:#E7E2D4;
  --sh-sm:0 6px 20px rgba(11,18,38,.06);
  --sh-md:0 14px 36px rgba(11,18,38,.10);
  --ff-d:'Playfair Display',Georgia,serif;
  --ff-b:'Plus Jakarta Sans',-apple-system,sans-serif;
  --ease:cubic-bezier(.22,1,.36,1);
  --r:14px;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--ink);font-family:var(--ff-b);font-weight:400;font-size:15px;line-height:1.65;overflow-x:hidden;-webkit-font-smoothing:antialiased}
::selection{background:var(--gold);color:#fff}
img{max-width:100%;display:block}
a{color:inherit;text-decoration:none}
button{font-family:inherit;cursor:pointer}
.wrap{width:min(1140px,92vw);margin-inline:auto}

.sec{padding:clamp(3.2rem,7vw,5.5rem) 0}
.sec.alt{background:var(--bg-alt)}
.sec-head{max-width:640px;margin-bottom:clamp(1.8rem,4vw,2.6rem)}
.sec-head.center{margin-inline:auto;text-align:center}
.eyebrow{display:inline-flex;align-items:center;gap:.7rem;font-size:.64rem;letter-spacing:.3em;text-transform:uppercase;color:var(--gold);font-weight:700}
.eyebrow::before{content:"";width:26px;height:1px;background:var(--gold)}
.sec-head.center .eyebrow::after{content:"";width:26px;height:1px;background:var(--gold)}
.h2{font-family:var(--ff-d);font-weight:600;font-size:clamp(1.55rem,3.4vw,2.4rem);line-height:1.18;letter-spacing:-.01em;margin:.55rem 0 .6rem;color:var(--ink)}
.h2 em{font-style:italic;color:var(--rose)}
.lede{color:var(--ink-2);font-size:.92rem;max-width:60ch}
.sec-head.center .lede{margin-inline:auto}

.reveal{opacity:0;transform:translateY(22px)}
.reveal.in{opacity:1;transform:none;transition:opacity .8s var(--ease),transform .8s var(--ease)}
.stag>*{opacity:0;transform:translateY(18px)}
.stag.in>*{opacity:1;transform:none;transition:opacity .7s var(--ease),transform .7s var(--ease)}
.stag.in>*:nth-child(2){transition-delay:.07s}.stag.in>*:nth-child(3){transition-delay:.14s}
.stag.in>*:nth-child(4){transition-delay:.21s}.stag.in>*:nth-child(5){transition-delay:.28s}
.stag.in>*:nth-child(6){transition-delay:.35s}

/* Loader */
#loader{position:fixed;inset:0;background:var(--bg);z-index:200;display:grid;place-items:center;transition:opacity .7s var(--ease),visibility .7s}
#loader.done{opacity:0;visibility:hidden}
#loader svg{width:78px;height:78px}
#loader .bl-petal{stroke-dasharray:300;stroke-dashoffset:300;animation:draw 1.4s var(--ease) forwards}
#loader .bl-petal:nth-child(2){animation-delay:.1s}#loader .bl-petal:nth-child(3){animation-delay:.2s}
#loader .bl-petal:nth-child(4){animation-delay:.3s}#loader .bl-petal:nth-child(5){animation-delay:.4s}
#loader .bl-petal:nth-child(6){animation-delay:.5s}
#loader p{margin-top:1rem;font-size:.58rem;letter-spacing:.4em;text-transform:uppercase;color:var(--ink-2);text-align:center}
@keyframes draw{to{stroke-dashoffset:0}}

/* Nav */
nav{position:fixed;inset:0 0 auto;z-index:100;background:rgba(251,250,247,.86);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border-bottom:1px solid transparent;transition:border-color .4s,box-shadow .4s}
nav.scrolled{border-color:var(--border);box-shadow:0 4px 24px rgba(11,18,38,.05)}
.nav-in{display:flex;align-items:center;justify-content:space-between;padding:.7rem 0;gap:1rem}
.brand{display:flex;align-items:center;gap:.6rem;min-width:0}
.brand svg{width:28px;height:28px;flex:none}
.brand span{font-weight:700;letter-spacing:.26em;font-size:.8rem;color:var(--ink);line-height:1.2}
.brand small{display:block;font-size:.46rem;letter-spacing:.24em;color:var(--rose);font-weight:500;margin-top:1px;white-space:nowrap}
.nav-links{display:flex;gap:1.5rem;font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-2);font-weight:600}
.nav-links a{position:relative;padding:.25rem 0;transition:color .3s}
.nav-links a::after{content:"";position:absolute;left:0;bottom:0;width:0;height:1.5px;background:var(--gold);transition:width .3s var(--ease)}
.nav-links a:hover{color:var(--ink)}.nav-links a:hover::after{width:100%}
.nav-cta{border:none;background:var(--ink);color:#fff;padding:.55rem 1.15rem;border-radius:99px;font-size:.64rem;letter-spacing:.14em;text-transform:uppercase;font-weight:700;transition:.3s var(--ease);white-space:nowrap}
.nav-cta:hover{background:var(--gold)}
#burger{display:none;background:none;border:none;width:38px;height:38px;flex:none;position:relative}
#burger span{position:absolute;left:8px;right:8px;height:2px;background:var(--ink);border-radius:2px;transition:.35s var(--ease)}
#burger span:nth-child(1){top:13px}#burger span:nth-child(2){top:19px}#burger span:nth-child(3){top:25px}
#burger.open span:nth-child(1){top:19px;transform:rotate(45deg)}
#burger.open span:nth-child(2){opacity:0}
#burger.open span:nth-child(3){top:19px;transform:rotate(-45deg)}
#mobileMenu{display:none;flex-direction:column;padding:.4rem 0 1rem;border-top:1px solid var(--border)}
#mobileMenu a{padding:.65rem .2rem;font-size:.78rem;letter-spacing:.12em;text-transform:uppercase;font-weight:600;color:var(--ink-2);border-bottom:1px solid var(--border)}
#mobileMenu a:last-child{border-bottom:none}
@media(max-width:920px){
  .nav-links,.nav-cta{display:none}
  #burger{display:block}
  #mobileMenu.show{display:flex}
}

/* Hero */
#hero{position:relative;overflow:hidden;color:#F4F1E9;background:
  radial-gradient(760px 460px at 82% 12%,rgba(46,77,196,.30),transparent 62%),
  radial-gradient(620px 420px at 8% 92%,rgba(185,106,126,.20),transparent 60%),
  linear-gradient(180deg,#0A0F22,#101A38 60%,#0A0F22)}
#bloom{position:absolute;width:min(60vw,460px);height:min(60vw,460px);right:-8%;top:50%;transform:translateY(-50%);opacity:.15;animation:spin 80s linear infinite;pointer-events:none}
@keyframes spin{to{transform:translateY(-50%) rotate(360deg)}}
.hero-in{position:relative;z-index:2;padding:6.2rem 0 3rem}
.hero-tag{display:inline-flex;align-items:center;gap:.6rem;border:1px solid rgba(234,215,164,.3);background:rgba(255,255,255,.05);border-radius:99px;padding:.4rem 1rem;font-size:.6rem;letter-spacing:.26em;text-transform:uppercase;color:var(--champagne)}
.hero-tag i{width:5px;height:5px;border-radius:50%;background:var(--rose);box-shadow:0 0 8px var(--rose);animation:pulse 2.4s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.35}}
h1{font-family:var(--ff-d);font-weight:600;font-size:clamp(1.95rem,5.6vw,3.7rem);line-height:1.12;letter-spacing:-.015em;margin:1.1rem 0 .9rem;max-width:17ch}
h1 .ln{display:block;overflow:hidden}
h1 .ln span{display:block;transform:translateY(110%);animation:rise 1s var(--ease) forwards}
h1 .ln:nth-child(2) span{animation-delay:.14s}
h1 .ln:nth-child(2){background:linear-gradient(100deg,var(--champagne) 15%,#D7A96A 50%,var(--rose-soft) 95%);-webkit-background-clip:text;background-clip:text;color:transparent;font-style:italic}
@keyframes rise{to{transform:none}}
.hero-sub{color:#B9BFCF;max-width:54ch;margin-bottom:1.6rem;font-size:.92rem}
.cta-row{display:flex;gap:.7rem;flex-wrap:wrap}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:.5rem;padding:.75rem 1.5rem;border-radius:99px;font-size:.66rem;letter-spacing:.16em;text-transform:uppercase;font-weight:700;transition:.35s var(--ease)}
.btn-gold{background:linear-gradient(115deg,#C6A15B,#B08B45);color:#0A0F22;border:none;box-shadow:0 10px 28px rgba(198,161,91,.3)}
.btn-gold:hover{transform:translateY(-2px);box-shadow:0 16px 36px rgba(198,161,91,.42)}
.btn-ghost{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.2);color:#fff}
.btn-ghost:hover{border-color:var(--champagne);color:var(--champagne);transform:translateY(-2px)}
.hero-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.1);border-radius:var(--r);overflow:hidden;margin-top:2.6rem}
.hstat{background:rgba(10,15,34,.55);padding:1rem .6rem;text-align:center;backdrop-filter:blur(8px)}
.hstat b{display:block;font-family:var(--ff-d);font-weight:600;font-size:clamp(1.25rem,2.6vw,1.8rem);color:var(--champagne);line-height:1.15}
.hstat span{font-size:.56rem;letter-spacing:.2em;text-transform:uppercase;color:#9AA2B5}
@media(max-width:640px){
  .hero-in{padding:5.4rem 0 2.4rem}
  .hero-stats{grid-template-columns:repeat(2,1fr)}
  .btn{flex:1 1 auto}
}

/* About */
.about-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:clamp(1.8rem,4.5vw,3.6rem);align-items:start}
.about-quote{font-family:var(--ff-d);font-style:italic;font-size:clamp(1.15rem,2.2vw,1.5rem);color:var(--rose);border-left:2px solid var(--gold);padding-left:1.1rem;margin:1.3rem 0}
.pillars{display:grid;gap:.75rem}
.pillar{display:flex;gap:.95rem;background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:1rem 1.1rem;box-shadow:var(--sh-sm);transition:.35s var(--ease)}
.pillar:hover{transform:translateY(-3px);box-shadow:var(--sh-md);border-color:var(--gold)}
.pillar svg{flex:none;width:30px;height:30px;color:var(--gold);margin-top:.15rem}
.pillar h3{font-family:var(--ff-d);font-size:.98rem;font-weight:600;margin-bottom:.15rem;color:var(--ink)}
.pillar p{font-size:.82rem;color:var(--ink-2);line-height:1.55}
@media(max-width:860px){.about-grid{grid-template-columns:1fr}}

/* Divisions */
.div-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.9rem}
.division{background:var(--card);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;box-shadow:var(--sh-sm);transition:.4s var(--ease);display:flex;flex-direction:column}
.division:hover{transform:translateY(-5px);box-shadow:var(--sh-md);border-color:var(--gold)}
.division .dimg{height:170px;overflow:hidden;position:relative;background:linear-gradient(135deg,#101A38,#2E4DC4 60%,#B96A7E)}
.division img{width:100%;height:100%;object-fit:cover;transition:transform .7s var(--ease)}
.division:hover img{transform:scale(1.06)}
.division .dtag{position:absolute;top:10px;left:10px;background:rgba(10,15,34,.78);color:var(--champagne);font-size:.52rem;letter-spacing:.22em;text-transform:uppercase;font-weight:700;padding:.3rem .7rem;border-radius:99px;backdrop-filter:blur(6px)}
.division .dbody{padding:1.2rem 1.2rem 1.3rem;display:flex;flex-direction:column;flex:1}
.division h3{font-family:var(--ff-d);font-size:1.15rem;font-weight:600;color:var(--ink);margin-bottom:.35rem}
.division p{font-size:.82rem;color:var(--ink-2);flex:1}
.division .more{display:inline-flex;align-items:center;gap:.4rem;margin-top:.9rem;font-size:.6rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);font-weight:700}
.division .more::after{content:"→";transition:transform .3s}
.division:hover .more::after{transform:translateX(4px)}
@media(max-width:860px){.div-grid{grid-template-columns:1fr}}

/* Flagship events */
.ev-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:.85rem}
.ev{position:relative;border-radius:var(--r);overflow:hidden;border:1px solid var(--border);box-shadow:var(--sh-sm);height:230px;transition:.4s var(--ease);cursor:pointer;background:linear-gradient(150deg,#101A38,#2E4DC4 55%,#B8924A)}
.ev:hover{transform:translateY(-4px);box-shadow:var(--sh-md)}
.ev img{width:100%;height:100%;object-fit:cover;transition:transform .7s var(--ease)}
.ev:hover img{transform:scale(1.06)}
.ev .evtxt{position:absolute;inset:auto 0 0;padding:2.2rem 1.1rem .95rem;background:linear-gradient(transparent,rgba(10,15,34,.88))}
.ev h3{font-family:var(--ff-d);font-size:1.02rem;font-weight:600;color:#fff;line-height:1.3}
.ev p{font-size:.68rem;color:#C9CFDD;margin-top:.15rem}
.ev .evtag{position:absolute;top:10px;right:10px;background:rgba(251,250,247,.9);color:var(--ink);font-size:.52rem;letter-spacing:.18em;text-transform:uppercase;font-weight:700;padding:.28rem .65rem;border-radius:99px}

/* Timeline */
.tl{display:grid;grid-template-columns:repeat(5,1fr);margin-top:2.6rem;position:relative}
.tl::before{content:"";position:absolute;top:8px;left:8%;right:8%;height:1.5px;background:var(--border)}
.tl-progress{position:absolute;top:8px;left:8%;height:1.5px;width:84%;background:linear-gradient(90deg,var(--rose),var(--gold));transform:scaleX(0);transform-origin:left;transition:transform 1.6s var(--ease)}
.tl.in .tl-progress{transform:scaleX(1)}
.tl-item{text-align:center;padding:0 .6rem}
.tl-item i{display:block;width:16px;height:16px;border-radius:50%;border:1.5px solid var(--gold);background:var(--bg);margin:0 auto 1rem;position:relative;z-index:1}
.tl-item i::after{content:"";position:absolute;inset:3.5px;border-radius:50%;background:var(--gold);transform:scale(0);transition:transform .5s var(--ease)}
.tl.in .tl-item i::after{transform:scale(1)}
.tl.in .tl-item:nth-child(3) i::after{transition-delay:.28s}.tl.in .tl-item:nth-child(4) i::after{transition-delay:.56s}
.tl.in .tl-item:nth-child(5) i::after{transition-delay:.84s}.tl.in .tl-item:nth-child(6) i::after{transition-delay:1.12s}
.tl-item b{display:block;font-family:var(--ff-d);font-size:1.05rem;font-weight:700;color:var(--gold);margin-bottom:.15rem}
.tl-item h3{font-family:var(--ff-d);font-size:.94rem;font-weight:600;color:var(--ink);margin-bottom:.2rem}
.tl-item p{font-size:.72rem;color:var(--ink-2);line-height:1.5}
@media(max-width:820px){
  .tl{grid-template-columns:1fr;gap:1.3rem}
  .tl::before,.tl-progress{display:none}
  .tl-item{display:flex;gap:.9rem;text-align:left;align-items:flex-start;flex-wrap:wrap}
  .tl-item i{margin:.2rem 0 0}
  .tl-item b{width:100%;margin-left:1.6rem;margin-top:-1.4rem}
}

/* Why partner */
.why-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:.75rem}
.why{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:1.3rem 1.2rem;transition:.35s var(--ease);box-shadow:var(--sh-sm)}
.why:hover{border-color:var(--rose);transform:translateY(-3px);box-shadow:var(--sh-md)}
.why svg{width:28px;height:28px;color:var(--rose);margin-bottom:.7rem}
.why h3{font-family:var(--ff-d);font-size:.98rem;font-weight:600;color:var(--ink);margin-bottom:.25rem}
.why p{font-size:.78rem;color:var(--ink-2)}

/* Stories */
.news-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:.85rem}
.ncard{background:var(--card);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;transition:.35s var(--ease);box-shadow:var(--sh-sm);display:block}
.ncard:hover{transform:translateY(-4px);border-color:var(--gold);box-shadow:var(--sh-md)}
.ncard .nimg{height:150px;overflow:hidden;background:linear-gradient(135deg,#101A38,#B96A7E 70%,#B8924A)}
.ncard img{width:100%;height:100%;object-fit:cover;transition:transform .7s var(--ease)}
.ncard:hover img{transform:scale(1.05)}
.ncard .nbody{padding:1.05rem 1.1rem 1.2rem}
.ncard time{font-size:.56rem;letter-spacing:.22em;text-transform:uppercase;color:var(--rose);font-weight:600}
.ncard h3{font-family:var(--ff-d);font-size:.98rem;font-weight:600;color:var(--ink);margin:.4rem 0 .3rem;line-height:1.35}
.ncard p{font-size:.78rem;color:var(--ink-2)}
.ncard .more{display:inline-flex;align-items:center;gap:.4rem;margin-top:.7rem;font-size:.58rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);font-weight:700}
.ncard .more::after{content:"→";transition:transform .3s}
.ncard:hover .more::after{transform:translateX(4px)}

/* Stats band */
.stat-band{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:var(--r);overflow:hidden}
.sb{background:var(--card);padding:1.5rem .7rem;text-align:center;transition:.3s}
.sb:hover{background:var(--bg-alt)}
.sb b{display:block;font-family:var(--ff-d);font-weight:600;font-size:clamp(1.35rem,2.8vw,2rem);color:var(--ink);line-height:1.15}
.sb b i{color:var(--gold);font-style:normal}
.sb span{font-size:.56rem;letter-spacing:.2em;text-transform:uppercase;color:var(--ink-2)}
@media(max-width:820px){.stat-band{grid-template-columns:repeat(2,1fr)}}

/* CTA */
#cta{position:relative;overflow:hidden;color:#F4F1E9;background:
 radial-gradient(560px 340px at 50% 0%,rgba(46,77,196,.32),transparent 65%),
 radial-gradient(480px 320px at 85% 100%,rgba(185,106,126,.2),transparent 60%),var(--dark-2)}
.cta-in{text-align:center;position:relative;z-index:2}
#cta .h2{color:#fff}
#cta .h2 em{color:var(--champagne)}
#cta .lede{color:#B9BFCF}
.cta-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:.7rem;margin-top:1.9rem}
.cta-tile{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.13);border-radius:var(--r);padding:1.2rem .9rem;transition:.35s var(--ease)}
.cta-tile:hover{border-color:var(--champagne);transform:translateY(-4px);background:rgba(198,161,91,.1)}
.cta-tile b{font-family:var(--ff-d);font-size:1.05rem;font-weight:600;color:var(--champagne);display:block;margin-bottom:.25rem}
.cta-tile span{font-size:.72rem;color:#B9BFCF;line-height:1.45;display:block}

/* Footer */
footer.site{background:var(--dark);color:#B9BFCF;padding:3rem 0 1.6rem}
.f-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr 1.2fr;gap:1.8rem}
.f-grid h4{font-size:.6rem;letter-spacing:.26em;text-transform:uppercase;color:var(--champagne);margin-bottom:.8rem}
.f-grid a{display:block;font-size:.78rem;color:#9AA2B5;padding:.22rem 0;transition:color .3s}
.f-grid a:hover{color:#fff}
footer .brand span{color:#fff}
footer .brand small{color:var(--rose-soft)}
.f-brand p{font-size:.78rem;color:#9AA2B5;max-width:32ch;margin-top:.8rem;line-height:1.6}
.socials{display:flex;gap:.55rem;margin-top:1rem;flex-wrap:wrap}
.socials a{width:34px;height:34px;border:1px solid rgba(255,255,255,.16);border-radius:50%;display:grid;place-items:center;color:#9AA2B5;transition:.3s;padding:0}
.socials a:hover{border-color:var(--champagne);color:var(--champagne);transform:translateY(-2px)}
.socials svg{width:13px;height:13px}
.newsletter{display:flex;border:1px solid rgba(255,255,255,.18);border-radius:99px;overflow:hidden;margin-top:.3rem}
.newsletter input{flex:1;min-width:0;background:transparent;border:none;outline:none;padding:.65rem 1rem;color:#fff;font-family:inherit;font-size:.78rem}
.newsletter button{background:var(--gold);border:none;color:#fff;padding:0 1.1rem;font-size:.58rem;letter-spacing:.12em;text-transform:uppercase;font-weight:700;transition:.3s;white-space:nowrap}
.newsletter button:hover{background:var(--champagne);color:var(--dark)}
.copy{margin-top:2.2rem;padding-top:1.3rem;border-top:1px solid rgba(255,255,255,.08);display:flex;justify-content:space-between;gap:.8rem;flex-wrap:wrap;font-size:.66rem;color:#6A7386}
@media(max-width:860px){.f-grid{grid-template-columns:1fr 1fr}}
@media(max-width:520px){.f-grid{grid-template-columns:1fr}}

@media (prefers-reduced-motion:reduce){
  *,*::before,*::after{animation-duration:.01ms!important;animation-iteration-count:1!important;transition-duration:.01ms!important}
  html{scroll-behavior:auto}
  .reveal,.stag>*{opacity:1;transform:none}
}
